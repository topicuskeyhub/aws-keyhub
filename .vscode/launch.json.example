  "version": "0.2.0",
  "configurations": [

    {
      "name": "Launch aws-keyhub",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "args": ["login", "-v", "-r", "arn:aws:iam::123456789012:role/name-of-your-role"]
    }
  ]
}